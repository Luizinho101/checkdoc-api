{
  "openapi": "3.0.0",
  "info": {
    "title": "CheckDoc API",
    "version": "1.0.0",
    "description": "API para validação de documentos (CPF, etc.) para fins de portfólio."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    },
    {
      "url": "https://seu-projeto-vercel.vercel.app",
      "description": "Servidor de Produção (Vercel)"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Retorna a mensagem padrão da API",
        "responses": {
          "200": {
            "description": "API funcionando corretamente.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "online"
                    },
                    "message": {
                      "type": "string",
                      "example": "CheckDoc API está online e operando com sucesso!"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/cpf": {
      "post": {
        "summary": "Valida um número de CPF",
        "description": "Recebe o CPF no corpo da requisição e retorna se é válido ou não.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cpf": {
                    "type": "string",
                    "example": "43450990721"
                  }
                },
                "required": [
                  "cpf"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resultado da validação do CPF",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "cpf": {
                      "type": "string",
                      "example": "43450990721"
                    },
                    "valido": {
                      "type": "boolean",
                      "example": true
                    },
                    "mensagem": {
                      "type": "string",
                      "example": "CPF válido!"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Requisição inválida ou campo CPF ausente"
          }
        }
      }
    }
  }
}